rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null && 
             request.auth.uid in [
               "<UID_USER_1>", 
               "<UID_USER_2>"
             ];
    }

    // Core chat
    match /messages/{id}          { allow read, write: if isAllowed(); }
    match /sharedNote/{id}        { allow read, write: if isAllowed(); }
    match /pinnedMessages/{id}    { allow read, write: if isAllowed(); }
    match /typingStatus/{uid}     { allow read, write: if isAllowed(); }
    match /userPresence/{uid}     { allow read, write: if isAllowed(); }
    match /aiMemory/{id}          { allow read, write: if isAllowed(); }

    // Calls (WebRTC signaling)
    match /calls/{callId} { 
      allow read, write: if isAllowed();
      match /callerCandidates/{c} { allow read, write: if isAllowed(); }
      match /calleeCandidates/{c} { allow read, write: if isAllowed(); }
    }

    // Games
    match /games/{gameType}/{col}/{docId} { 
      allow read, write: if isAllowed(); 
    }
    match /pandaMemory/{id}       { allow read, write: if isAllowed(); }

    // User preferences & tokens
    match /userPreferences/{uid}  { 
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }
    match /users/{uid}/tokens/{t} { 
      allow read, write: if isAllowed() && request.auth.uid == uid;
    }

    // Encryption salt (read-only after creation)
    match /appConfig/{id}         { 
      allow read: if isAllowed();
      allow write: if false;
    }
  }
}
