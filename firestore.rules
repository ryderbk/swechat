rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null;
    }

    match /messages/{messageId} {
      allow read: if isAllowed();
      allow create: if isAllowed()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAll(['senderId', 'createdAt', 'type']);
      allow update: if isAllowed()
        && (
          resource.data.senderId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'reactions', 'starred'])
        );
      allow delete: if isAllowed() && resource.data.senderId == request.auth.uid;
    }

    match /sharedNote/{docId} {
      allow read, write: if isAllowed();
    }

    match /typingStatus/{uid} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }

    match /userPresence/{uid} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }

    match /pinnedMessages/{docId} {
      allow read, write: if isAllowed();
    }

    match /calls/{callId} {
      allow read, write: if isAllowed();
    }

    match /calls/{callId}/callerCandidates/{candidateId} {
      allow read, write: if isAllowed();
    }

    match /calls/{callId}/calleeCandidates/{candidateId} {
      allow read, write: if isAllowed();
    }

    match /userPreferences/{uid} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }

    match /users/{uid}/tokens/{tokenId} {
      allow read, write: if isAllowed() && request.auth.uid == uid;
    }

    match /appConfig/{docId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
