modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SweeTalk"

[[workflows.workflow]]
name = "SweeTalk"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23153 BASE_PATH=/sweetalk/ pnpm --filter @workspace/sweetalk run dev"
waitForPort = 23153

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23153
externalPort = 3000

[userenv]

[userenv.shared]
VITE_FIREBASE_API_KEY = "AIzaSyAOzvLy-vW4zaSwUPo-iXvxRiCe7Acz8Oo"
VITE_FIREBASE_AUTH_DOMAIN = "swechat11.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "swechat11"
VITE_FIREBASE_STORAGE_BUCKET = "swechat11.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "42018264553"
VITE_FIREBASE_APP_ID = "1:42018264553:web:aa9257c7cedc2c27f9e778"
