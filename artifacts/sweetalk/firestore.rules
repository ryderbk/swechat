rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null;
    }

    // Messages: allow read/write for authenticated users
    match /messages/{messageId} {
      allow read: if isAllowed();
      allow create: if isAllowed();
      allow update: if isAllowed();
      allow delete: if isAllowed() && resource.data.senderId == request.auth.uid;
    }

    // Presence & Typing: Essential for the real-time indicators
    match /userPresence/{uid} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }

    match /typingStatus/{uid} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == uid;
    }

    // Login Activity: This was likely the culprit!
    match /loginActivity/{logId} {
      allow read: if isAllowed();
      allow create: if isAllowed();
    }

    // Shared Note
    match /sharedNote/{docId} {
      allow read, write: if isAllowed();
    }

    // AI Memory (Panda chat memory)
    match /aiMemory/{docId} {
      allow read, write: if isAllowed();
    }

    // User Preferences (mute, theme, etc.)
    match /userPreferences/{uid} {
      allow read, write: if isAllowed();
    }

    // Pinned Messages
    match /pinnedMessages/{docId} {
      allow read, write: if isAllowed();
    }

    // Starred / calls
    match /calls/{callId} {
      allow read, write: if isAllowed();
    }

    // Games system
    match /games/{gameType}/rounds/{roundId} {
      allow read, write: if isAllowed();
    }
    match /games/{gameType}/days/{dayId} {
      allow read, write: if isAllowed();
    }
    match /games/{gameType}/entries/{entryId} {
      allow read, write: if isAllowed();
    }
    match /games/{gameType}/rooms/{roomId} {
      allow read, write: if isAllowed();
    }

    // Panda Memory (evolving AI context for games)
    match /pandaMemory/{docId} {
      allow read, write: if isAllowed();
    }

    // Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
