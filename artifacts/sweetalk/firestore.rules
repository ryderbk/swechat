rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // ── Messages ──────────────────────────────────────────────
    match /messages/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuth()
        && (resource.data.senderId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'reactions', 'starred']));
      allow delete: if isAuth()
        && resource.data.senderId == request.auth.uid;
    }

    // ── Shared Note ───────────────────────────────────────────
    match /sharedNote/{docId} {
      allow read, write: if isAuth();
    }

    // ── Typing indicators ─────────────────────────────────────
    match /typing/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Presence ──────────────────────────────────────────────
    match /presence/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Pinned Messages ───────────────────────────────────────
    match /pinnedMessages/{pinId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Calls (WebRTC signaling) ───────────────────────────────
    match /calls/{callId} {
      allow read, write: if isAuth();
    }

    // ── User Preferences ──────────────────────────────────────
    match /userPreferences/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // ── FCM Tokens ────────────────────────────────────────────
    match /fcmTokens/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── App Config (e.g. mute settings) ───────────────────────
    match /appConfig/{docId} {
      allow read, write: if isAuth();
    }

    // ── Starred Messages ──────────────────────────────────────
    match /starredMessages/{docId} {
      allow read, write: if isAuth();
    }
  }
}
